# === API Keys ===
ELEVENLABS_API_KEY=your-elevenlabs-api-key
OPENAI_API_KEY=your-openai-api-key  # only needed if STT_PROVIDER=openai

# === STT (Speech-to-Text) ===
STT_PROVIDER=elevenlabs              # "elevenlabs" or "openai"
ELEVENLABS_STT_MODEL=scribe_v1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=en

# === TTS (Text-to-Speech) ===
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL_ID=eleven_v3        # eleven_v3, eleven_flash_v2_5, etc.

# === LLM (via PicoClaw) ===
PICOCLAW_BIN=/home/plue/picoclaw
PICOCLAW_MODEL=kimi-turbo
PICOCLAW_SESSION=voice:assistant

# === Audio ===
SAMPLE_RATE=16000
INPUT_DEVICE_HINT=USB                 # substring match for mic device name
OUTPUT_DEVICE_HINT=USB                # substring match for speaker device name

# === Voice Activity Detection ===
SILENCE_THRESHOLD=0.015               # RMS threshold for speech detection
SILENCE_DURATION=1.5                  # seconds of silence before auto-stop
MIN_SPEECH_DURATION=0.5               # minimum recording length
MAX_RECORD_SECONDS=30                 # safety cap

# === Input Mode ===
INPUT_MODE=auto                       # "gpio", "keyboard", or "auto"
GPIO_BUTTON_PIN=17                    # GPIO pin for physical button

# === Button Gestures (GPIO mode) ===
HOLD_THRESHOLD=0.3                    # seconds — shorter = tap, longer = PTT hold
TAP_WINDOW=0.4                        # seconds to wait for additional taps

# === Startup ===
STARTUP_MESSAGE=[excited] Hey hey hey! I'm awake! What's up?
IDLE_CHATTER=1                        # enable random idle comments
IDLE_INTERVAL_MIN=5                   # min minutes between idle lines
IDLE_INTERVAL_MAX=15                  # max minutes between idle lines
